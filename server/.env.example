# === Neonix server env ===
# Server
PORT=4000
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL="postgresql://neonix:neonix_dev@localhost:5432/neonix?schema=public"

# Auth
JWT_ACCESS_SECRET=change_me_access_secret_dev_only
JWT_REFRESH_SECRET=change_me_refresh_secret_dev_only
ACCESS_TTL=15m
REFRESH_TTL=30d

# Telegram Bot
TG_BOT_NAME=manager_neonix_bot
